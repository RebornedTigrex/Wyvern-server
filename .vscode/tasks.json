{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "Wyvern: clean + build (all)",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}\\build.ps1",
				"-Clean"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"detail": "Очистка и полная сборка проекта через build.ps1."
		}
	]
}
